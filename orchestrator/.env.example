# =============================================================================
# RUDRA ORCHESTRATOR CONFIGURATION
# =============================================================================
# These environment variables are referenced in WORKFLOW.md via $VAR_NAME syntax.
# Rudra resolves them at startup.
# =============================================================================

# Linear API key (required)
LINEAR_API_KEY=

# GitHub token for PR creation and API access (required)
GITHUB_TOKEN=

# GitHub webhook secret for signature verification (optional)
GITHUB_WEBHOOK_SECRET=

# Rudra API key — protects the REST API (required)
RUDRA_API_KEY=

# Rudra API server config (optional)
RUDRA_API_PORT=3847
RUDRA_API_HOST=0.0.0.0
RUDRA_CORS_ORIGIN=http://localhost:3000

# Logs directory (optional, default: ~/.rudra-runs)
RUDRA_LOGS_ROOT=

# Slack notifications (optional)
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
