digraph RevisionPipeline {
  graph [goal="Address GitHub PR review feedback and update the existing pull request"]

  start [shape=Mdiamond]
  exit  [shape=Msquare]

  revise [
    type="agent",
    label="Revise",
    agent="reviser",
    artifact_path=".rudra/run/revision-summary.md"
  ]

  update_pr [
    type="agent",
    label="Prepare PR Update",
    agent="revision-pr-preparer",
    artifact_path=".rudra/run/pr-body.md"
  ]

  publish_pr_update [
    type="tool",
    label="Update PR",
    command="rudra update-pr --title-file .rudra/pr-title.txt --body-file .rudra/run/pr-body.md"
  ]

  start -> revise -> update_pr -> publish_pr_update -> exit
}
